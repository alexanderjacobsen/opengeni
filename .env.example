# Copy to .env and fill in. Never commit .env.

OPENGENI_SERVICE_NAME=opengeni
OPENGENI_ENVIRONMENT=local
OPENGENI_DATABASE_URL=postgres://opengeni:opengeni@127.0.0.1:5432/opengeni
OPENGENI_NATS_URL=nats://127.0.0.1:4222
OPENGENI_TEMPORAL_HOST=127.0.0.1:7233
OPENGENI_TEMPORAL_NAMESPACE=default
OPENGENI_TEMPORAL_TASK_QUEUE=opengeni-runs-ts
OPENGENI_STARTUP_DEPENDENCY_RETRY_ATTEMPTS=30
OPENGENI_STARTUP_DEPENDENCY_RETRY_INITIAL_DELAY_MS=1000
OPENGENI_STARTUP_DEPENDENCY_RETRY_MAX_DELAY_MS=5000
OPENGENI_OBSERVABILITY_STRUCTURED_LOGS=false
OPENGENI_OBSERVABILITY_METRICS_ENABLED=true
# OPENGENI_OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OPENGENI_OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer token
# Optional deployment shared-key boundary. This is an infra/edge gate, not the
# product API key system. When enabled, protected API, MCP, file, document,
# session, scheduled-task, billing, and SSE routes require:
#   x-opengeni-access-key: <OPENGENI_ACCESS_KEY>
# Product API keys and delegated access tokens use Authorization: Bearer instead.
OPENGENI_AUTH_REQUIRED=false
# OPENGENI_ACCESS_KEY=replace-with-a-long-random-deployment-key
OPENGENI_AUTH_ALLOW_HEALTH=true
OPENGENI_AUTH_ALLOW_METRICS=false
OPENGENI_API_HOST=0.0.0.0
OPENGENI_API_PORT=8000
# CORS origin allowlist regex. The API matches this as a full-string regex.
OPENGENI_CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Optional Docker Compose host port overrides. `bun run dev` auto-selects free
# ports when these defaults are occupied and rewrites the runtime env in memory.
OPENGENI_POSTGRES_HOST_PORT=5432
OPENGENI_NATS_HOST_PORT=4222
OPENGENI_NATS_MONITOR_HOST_PORT=8222
OPENGENI_TEMPORAL_HOST_PORT=7233
OPENGENI_MINIO_HOST_PORT=9000
OPENGENI_MINIO_CONSOLE_HOST_PORT=9001
OPENGENI_WEB_PORT=3000
# Comma-separated hosts accepted by Vite dev/preview. Required when the web
# container is exposed through a real staging/prod hostname.
# OPENGENI_WEB_ALLOWED_HOSTS=app.opengeni.ai,staging.app.opengeni.ai

# Product posture. Modes are intentionally separate from infrastructure profile.
# local: dev default workspace/subject. configured: self-host/embedded tokens or
# deployment key. managed: Better Auth email/password for humans plus OpenGeni API keys.
OPENGENI_PRODUCT_ACCESS_MODE=local
OPENGENI_BILLING_MODE=disabled
OPENGENI_ENTITLEMENTS_MODE=none
OPENGENI_USAGE_LIMITS_MODE=none
# OPENGENI_PUBLIC_BASE_URL=https://app.opengeni.ai
# OPENGENI_DELEGATION_SECRET=replace-with-long-random-token-signing-secret
# OPENGENI_STATIC_ENTITLEMENTS_JSON='{"feature_key":true}'
# OPENGENI_STATIC_USAGE_LIMITS_JSON='{"maxWorkspacesPerAccount":1,"maxMonthlyAgentRunsPerWorkspace":100}'

# Workspace environments (per-workspace secret env vars injected into attached runs).
# Required in managed mode outside local/test; without it the environment routes return 503.
# Generate with: openssl rand -base64 32
# OPENGENI_ENVIRONMENTS_ENCRYPTION_KEY=replace-with-base64-32-byte-key

# Session goal guard rails (see docs/goals.md). Goals are uncapped by count
# by default (agents legitimately run for days); set a max only if a
# deployment needs a hard ceiling. No-progress detection stays on. Defaults shown.
# OPENGENI_GOAL_MAX_AUTO_CONTINUATIONS=
# OPENGENI_GOAL_NO_PROGRESS_LIMIT=3

# Conversation-history source (issue #35; see docs/run-lifecycle.md). Items +
# the sandbox envelope are dual-written unconditionally; this flips the READ
# path only. Default is "items" (SDK-native history items from the DB); set
# "run_state" to fall back to the legacy serialized RunState blob.
# OPENGENI_SESSION_HISTORY_SOURCE=run_state

# Managed mode human auth and transactional email.
# OPENGENI_BETTER_AUTH_SECRET=replace-with-long-random-better-auth-secret
# OPENGENI_BETTER_AUTH_TRUSTED_ORIGINS=https://app.opengeni.ai,https://staging.app.opengeni.ai
# OPENGENI_BETTER_AUTH_ALLOWED_HOSTS=app.opengeni.ai,staging.app.opengeni.ai
# OPENGENI_BETTER_AUTH_COOKIE_DOMAIN=.opengeni.ai
# OPENGENI_RESEND_API_KEY=re_...

# Stripe test/live billing. First release uses prepaid credit Checkout payments.
# Route/domain code checks local credit ledger, usage, and entitlements, not Stripe synchronously.
# OPENGENI_STRIPE_SECRET_KEY=sk_test_...
# OPENGENI_STRIPE_PUBLISHABLE_KEY=pk_test_...
# OPENGENI_STRIPE_WEBHOOK_SECRET=whsec_...
# Optional dedicated Stripe Product for flexible prepaid credit Checkout line items.
# OPENGENI_STRIPE_CREDITS_PRODUCT_ID=prod_...
# Production live-mode read-only preflight uses explicit live keys and live object ids.
# Do not set these to test-mode values.
# STRIPE_LIVE_SECRET_KEY=sk_live_...
# STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_LIVE_WEBHOOK_SECRET=whsec_...
# OPENGENI_STRIPE_LIVE_CREDITS_PRODUCT_ID=prod_...
# OPENGENI_STRIPE_LIVE_WEBHOOK_URL=https://app.opengeni.ai/v1/webhooks/stripe
# Optional override for model cost accounting. Values are micros of USD per
# million tokens, before marginBps.
# OPENGENI_MODEL_PRICING_JSON='{"gpt-5.5":{"inputMicrosPerMillionTokens":5000000,"cachedInputMicrosPerMillionTokens":500000,"outputMicrosPerMillionTokens":30000000,"marginBps":2500}}'

# OpenAI provider.
OPENGENI_OPENAI_PROVIDER=openai
OPENGENI_OPENAI_MODEL=gpt-5.5
OPENGENI_OPENAI_REASONING_EFFORT=low
OPENGENI_OPENAI_ALLOWED_MODELS=gpt-5.5,gpt-5.4,gpt-5.4-mini
OPENGENI_OPENAI_ALLOWED_REASONING_EFFORTS=low,medium,high,xhigh
OPENGENI_OPENAI_API_KEY=your-key
# OPENGENI_OPENAI_BASE_URL=https://api.openai.com/v1
# OPENGENI_OPENAI_RESPONSES_TRANSPORT=websocket
# OPENGENI_DISABLE_OPENAI_TRACING=true

# Azure OpenAI provider.
# OPENGENI_OPENAI_PROVIDER=azure
# OPENGENI_AZURE_OPENAI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/openai/v1
# OPENGENI_AZURE_OPENAI_API_KEY=your-key
# OPENGENI_AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# OPENGENI_AZURE_OPENAI_DEPLOYMENT=your-deployment
# Required only for endpoint/deployment-style Azure URLs. Azure /openai/v1 base URLs omit this query.
# OPENGENI_AZURE_OPENAI_API_VERSION=2025-04-01-preview
# OPENGENI_AZURE_OPENAI_AD_TOKEN=...

# Sandbox backend: docker, modal, local, or none.
OPENGENI_SANDBOX_BACKEND=docker
OPENGENI_DOCKER_IMAGE=opengeni-sandbox:local
OPENGENI_DOCKER_NETWORK=opengeni_default
# OPENGENI_DOCKER_EXPOSED_PORTS=3000,8080

# Modal sandbox backend.
OPENGENI_MODAL_APP_NAME=opengeni-sandbox
OPENGENI_MODAL_TIMEOUT_SECONDS=900
# OPENGENI_MODAL_IMAGE_REF=ghcr.io/YOUR_ORG/opengeni-sandbox:dev
# OPENGENI_MODAL_TOKEN_ID=ak-...
# OPENGENI_MODAL_TOKEN_SECRET=as-...
# OPENGENI_MODAL_ENVIRONMENT=main

# Sandbox preparation profiles. Profiles allow selected host env vars into the sandbox
# and may enable lifecycle hooks such as Azure CLI login. Default is safest for OSS.
# Supported profiles: none, azure, github.
OPENGENI_SANDBOX_PREPARATION_PROFILES=none
# Add extra host env var names to expose to sandbox manifests.
# OPENGENI_SANDBOX_ENV_ALLOWLIST=TF_VAR_region,CUSTOM_PROVIDER_TOKEN

# Session-level MCP tool providers. Clients select these by id with `tools: [{ "kind": "mcp", "id": "docs" }]`.
# Built-in API MCP defaults to http://127.0.0.1:${OPENGENI_API_PORT}/v1/workspaces/{workspaceId}/mcp and exposes scheduled task tools.
# A built-in `docs` provider can also be registered under the same workspace-scoped MCP surface unless overridden here.
# OPENGENI_MCP_URL=http://127.0.0.1:8000/v1/workspaces/{workspaceId}/mcp
# OPENGENI_MCP_SERVERS='[{"id":"docs","name":"Document Search","url":"http://127.0.0.1:8000/v1/workspaces/{workspaceId}/mcp/docs","allowedTools":["search_documents","fetch_document_chunk","list_document_bases"]}]'

# Object storage for uploaded files. Local Docker uses S3-compatible MinIO from docker-compose.yml.
OPENGENI_OBJECT_STORAGE_BACKEND=s3-compatible
OPENGENI_OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OPENGENI_OBJECT_STORAGE_SANDBOX_ENDPOINT=http://minio:9000
OPENGENI_OBJECT_STORAGE_BUCKET=opengeni-files
OPENGENI_OBJECT_STORAGE_REGION=us-east-1
OPENGENI_OBJECT_STORAGE_S3_PROVIDER=Minio
OPENGENI_OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OPENGENI_OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OPENGENI_OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Azure Blob production storage. Set OPENGENI_OBJECT_STORAGE_BACKEND=azure-blob and provide
# either a connection string or account name plus account key. The bucket value is the Azure container.
# OPENGENI_OBJECT_STORAGE_AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# OPENGENI_OBJECT_STORAGE_AZURE_ACCOUNT_NAME=...
# OPENGENI_OBJECT_STORAGE_AZURE_ACCOUNT_KEY=...
# OPENGENI_OBJECT_STORAGE_AZURE_ENDPOINT=https://account.blob.core.windows.net

# Native cloud object storage. Prefer workload identity in Kubernetes; static keys are optional.
# AWS S3:
# OPENGENI_OBJECT_STORAGE_BACKEND=aws-s3
# OPENGENI_OBJECT_STORAGE_BUCKET=opengeni-files
# OPENGENI_OBJECT_STORAGE_REGION=us-east-1
# GCS:
# OPENGENI_OBJECT_STORAGE_BACKEND=gcs
# OPENGENI_OBJECT_STORAGE_BUCKET=opengeni-files
# OPENGENI_OBJECT_STORAGE_GCS_PROJECT_ID=opengeni-project
# OPENGENI_OBJECT_STORAGE_GCS_KEY_FILENAME=/var/run/secrets/gcp/key.json
# OPENGENI_OBJECT_STORAGE_GCS_CREDENTIALS_JSON={"type":"service_account",...}

# Document indexing. V1 retrieval is semantic-only: LiteParse -> chunks -> embeddings -> pgvector.
OPENGENI_DOCUMENT_PARSER=liteparse
OPENGENI_DOCUMENT_CHUNK_SIZE=1200
OPENGENI_DOCUMENT_CHUNK_OVERLAP=160
OPENGENI_DOCUMENT_EMBEDDING_PROVIDER=openai
OPENGENI_DOCUMENT_EMBEDDING_MODEL=text-embedding-3-large
OPENGENI_DOCUMENT_EMBEDDING_DIMENSIONS=3072
# OPENGENI_DOCUMENT_EMBEDDING_API_KEY=sk-...
# OPENGENI_DOCUMENT_EMBEDDING_BASE_URL=https://api.openai.com/v1

# Explicit OpenGeni git identity used inside sandboxes. GitHub App runs default to the app bot identity.
# OPENGENI_GIT_AUTHOR_NAME=OpenGeni Agent
# OPENGENI_GIT_AUTHOR_EMAIL=opengeni-agent@example.com
# OPENGENI_GIT_COMMITTER_NAME=OpenGeni Agent
# OPENGENI_GIT_COMMITTER_EMAIL=opengeni-agent@example.com

# Actual sandbox credentials. Prefer short-lived credentials.
# When the azure preparation profile is enabled and ARM/AZURE service-principal vars are present,
# the worker pre-authenticates normal Azure CLI inside the sandbox before the agent starts.
# ARM_CLIENT_ID=...
# ARM_CLIENT_SECRET=...
# ARM_TENANT_ID=...
# ARM_SUBSCRIPTION_ID=...
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...
# AZURE_TENANT_ID=...
# AZURE_SUBSCRIPTION_ID=...
# GH_TOKEN=...
# GITHUB_TOKEN=...

# GitHub App manifest flow.
# OPENGENI_GITHUB_APP_MANIFEST_BASE_URL=https://YOUR_DOMAIN
# OPENGENI_GITHUB_APP_MANIFEST_STATE_SECRET=change-me
# OPENGENI_GITHUB_APP_ID=
# OPENGENI_GITHUB_CLIENT_ID=
# OPENGENI_GITHUB_CLIENT_SECRET=
# OPENGENI_GITHUB_APP_SLUG=
# OPENGENI_GITHUB_WEBHOOK_SECRET=
# OPENGENI_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
