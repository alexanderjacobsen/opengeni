project_id       = "opengeni-project"
name_prefix      = "opengeni-example"
region           = "us-central1"
zone             = "us-central1-a"
deployment_phase = "bootstrap"

gke = {
  deletion_protection = false
  node_count          = 1
  min_node_count      = 1
  max_node_count      = 2
}

labels = {
  environment = "verification"
  cleanup     = "delete-after-validation"
}

artifact_registry_writer_members = [
  "serviceAccount:ci-image-writer@opengeni-project.iam.gserviceaccount.com",
]

gke_admin_members = [
  "serviceAccount:platform-operator@opengeni-project.iam.gserviceaccount.com",
]

kubernetes_workload_identity = {
  namespace       = "opengeni-gcp"
  service_account = "opengeni-gcp"
}

postgres = {
  mode = "external"
  # existing_host = "postgres.example.com"
}

temporal = {
  mode = "external"
  # existing_host = "temporal.example.com:7233"
  namespace  = "default"
  task_queue = "opengeni-runs-ts"
}

object_storage = {
  mode          = "managed"
  force_destroy = true

  # In external mode, set bucket to an existing GCS bucket name.
  # bucket = "existing-opengeni-files"
}
