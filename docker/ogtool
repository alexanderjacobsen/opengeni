#!/usr/bin/env node

const http = require("node:http");
const https = require("node:https");
const fs = require("node:fs");

const tokenFile = process.env.OPENGENI_TOOLSPACE_TOKEN_FILE;
const url = process.env.OPENGENI_TOOLSPACE_URL;

function usage(exitCode = 1) {
  const out = [
    "usage:",
    "  ogtool tools/list",
    "  ogtool tools/call <tool-name> [json-args]",
    "",
    "requires OPENGENI_TOOLSPACE_TOKEN_FILE and OPENGENI_TOOLSPACE_URL",
  ].join("\n");
  (exitCode === 0 ? console.log : console.error)(out);
  process.exit(exitCode);
}

if (process.argv.includes("--help") || process.argv.includes("-h")) {
  usage(0);
}
if (!tokenFile || !url) {
  usage();
}

const token = fs.readFileSync(tokenFile, "utf8").trim();
let nextId = 1;
let sessionId = null;

function rpc(method, params) {
  return {
    jsonrpc: "2.0",
    id: nextId++,
    method,
    ...(params === undefined ? {} : { params }),
  };
}

function notify(method, params) {
  return {
    jsonrpc: "2.0",
    method,
    ...(params === undefined ? {} : { params }),
  };
}

function request(payload) {
  const target = new URL(url);
  const body = JSON.stringify(payload);
  const transport = target.protocol === "https:" ? https : http;
  const headers = {
    "accept": "application/json, text/event-stream",
    "authorization": `Bearer ${token}`,
    "content-type": "application/json",
    "content-length": Buffer.byteLength(body),
  };
  if (sessionId) {
    headers["mcp-session-id"] = sessionId;
  }
  return new Promise((resolve, reject) => {
    const req = transport.request(target, {
      method: "POST",
      headers,
    }, (res) => {
      const chunks = [];
      res.on("data", (chunk) => chunks.push(chunk));
      res.on("end", () => {
        const returnedSession = res.headers["mcp-session-id"];
        if (typeof returnedSession === "string" && returnedSession) {
          sessionId = returnedSession;
        }
        const text = Buffer.concat(chunks).toString("utf8");
        if (res.statusCode < 200 || res.statusCode >= 300) {
          reject(new Error(`HTTP ${res.statusCode}: ${text}`));
          return;
        }
        if (!text) {
          resolve(null);
          return;
        }
        try {
          resolve(JSON.parse(text));
        } catch (error) {
          reject(new Error(`non-JSON response: ${text}`));
        }
      });
    });
    req.on("error", reject);
    req.write(body);
    req.end();
  });
}

async function main() {
  const command = process.argv[2];
  await request(rpc("initialize", {
    protocolVersion: "2025-03-26",
    capabilities: {},
    clientInfo: { name: "ogtool", version: "0.1.0" },
  }));
  await request(notify("notifications/initialized"));

  let result;
  if (command === "tools/list" || command === "list") {
    result = await request(rpc("tools/list", {}));
  } else if (command === "tools/call" || command === "call") {
    const name = process.argv[3];
    if (!name) {
      usage();
    }
    const args = process.argv[4] ? JSON.parse(process.argv[4]) : {};
    result = await request(rpc("tools/call", { name, arguments: args }));
  } else {
    usage();
  }

  if (result && result.error) {
    console.error(JSON.stringify(result, null, 2));
    process.exit(2);
  }
  process.stdout.write(`${JSON.stringify(result?.result ?? result, null, 2)}\n`);
}

main().catch((error) => {
  console.error(error instanceof Error ? error.message : String(error));
  process.exit(1);
});
