{
  "name": "@opengeni/db",
  "version": "0.5.0",
  "description": "OpenGeni persistence: Drizzle schema, RLS-scoped query layer, the SQL migration runner, and role provisioning.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cloudgeni-ai/opengeni.git",
    "directory": "packages/db"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./migrate": {
      "types": "./src/migrate.ts",
      "default": "./src/migrate.ts"
    },
    "./provision-roles": {
      "types": "./src/provision-roles.ts",
      "default": "./src/provision-roles.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "drizzle"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "bun src/migrate.ts",
    "provision-roles": "bun src/provision-roles.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "prepublishOnly": "bun ../../scripts/prepublish-guard"
  },
  "dependencies": {
    "@opengeni/codex": "workspace:*",
    "@opengeni/config": "workspace:*",
    "@opengeni/contracts": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@opengeni/testing": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
