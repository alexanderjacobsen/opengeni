{
  "name": "@opengeni/react",
  "version": "0.1.0",
  "private": true,
  "description": "React hooks and styled components for OpenGeni: live session streaming, chat composer, message timeline, session status, and fleet views — token-themed (CSS variables), dark-first, built on Tailwind v4 + Radix + Motion.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./styles/index.css",
    "./tokens.css": "./styles/tokens.css"
  },
  "files": [
    "dist",
    "src",
    "styles"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && (cd ../sdk && bun run build) && tsc -p tsconfig.build.json",
    "demo": "vite dev demo --port 3100",
    "demo:build": "vite build demo"
  },
  "dependencies": {
    "@opengeni/sdk": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "motion": "^12.0.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@happy-dom/global-registrator": "^20.10.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  }
}
